{
  "name": "skillforge",
  "version": "1.0.0",
  "description": "A modern online learning platform for managing and delivering digital courses",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "test": "cd backend && npm test",
    "lint": "cd frontend && npm run lint",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules"
  },
  "keywords": [
    "education",
    "learning",
    "courses",
    "online-learning",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "SkillForge Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/skillforge.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/skillforge/issues"
  },
  "homepage": "https://github.com/your-username/skillforge#readme"
}
